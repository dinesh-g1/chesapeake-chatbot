# =============================================================================
# Caddyfile for Chesapeake City Agentic AI Chatbot
# =============================================================================
# Caddy automatically provisions and renews Let's Encrypt certificates.
# No manual certbot, dhparam, or SSL scripts needed.
#
# PRODUCTION (DOMAIN_NAME set, e.g. "chesapeakechatbot.chat"):
#   Caddy automatically:
#     - Obtains a Let's Encrypt certificate for the domain
#     - Serves HTTPS on :443
#     - Redirects HTTP :80 → HTTPS
#     - Applies all security headers and routing
#
# DEVELOPMENT (DOMAIN_NAME empty / unset):
#   Caddy falls back to serving plain HTTP on port 80.
#   Perfect for local testing without a real domain.
#
# Usage:
#   DOMAIN_NAME=chesapeakechatbot.chat docker compose up -d
# =============================================================================

# ── Global Options ──────────────────────────────────────────────────────────
# NO global options that would interfere with Let's Encrypt.
# Do NOT add "local_certs" — that blocks real certificate provisioning.
# Do NOT add "auto_https disable_redirects" — we WANT HTTP→HTTPS redirects.
{
    # Enable debug logging during initial setup (remove for production)
    # debug
}

# ═══════════════════════════════════════════════════════════════════════════════
# PRODUCTION — Site block for the domain
# ═══════════════════════════════════════════════════════════════════════════════
# When DOMAIN_NAME is set (e.g., "chesapeakechatbot.chat") this block activates.
# Caddy automatically handles:
#   - Let's Encrypt certificate provisioning and renewal
#   - HTTPS on port 443
#   - HTTP on port 80 (ACME challenge + redirect to HTTPS)
#
# When DOMAIN_NAME is empty, Caddy ignores this block (no error).
{$DOMAIN_NAME} {
    # ── Reverse proxy to the Next.js chatbot backend ───────────────────────
    reverse_proxy chatbot:3000 {
        # Forward protocol info so the app knows it's behind HTTPS
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-Host {host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Real-IP {remote_host}

        # WebSocket support (required for LLM streaming responses)
        header_up Upgrade {header.Upgrade}
        header_up Connection {header.Connection}
    }

    # ── Security Headers ───────────────────────────────────────────────────
    header {
        # HTTP Strict Transport Security — force HTTPS for 1 year
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        # Prevent clickjacking
        X-Frame-Options "SAMEORIGIN"
        # Prevent MIME type sniffing
        X-Content-Type-Options "nosniff"
        # Enable XSS filter in older browsers
        X-XSS-Protection "1; mode=block"
        # Referrer policy
        Referrer-Policy "strict-origin-when-cross-origin"
        # Restrict browser features
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
        # Content Security Policy
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://api.deepseek.com; frame-ancestors 'self';"
    }

    # ── Rate Limiting ──────────────────────────────────────────────────────
    # Protect API/chat endpoints from abuse (10 req/s per IP)
    @api_endpoints {
        path /api/chat*
        path /api/ingest*
    }
    rate_limit @api_endpoints {
        zone dynamic {
            key {remote_host}
            events 10
            window 1s
        }
    }

    # ── Access Logging ─────────────────────────────────────────────────────
    log {
        output file /var/log/caddy/access.log {
            roll_size 100mb
            roll_keep 5
            roll_keep_for 720h   # 30 days
        }
        format json
    }

    # ── Compression ────────────────────────────────────────────────────────
    encode gzip zstd

    # ── Static File Caching ────────────────────────────────────────────────
    @static_files {
        path *.js *.css *.png *.jpg *.jpeg *.gif *.ico *.svg *.woff *.woff2 *.ttf *.eot *.webp
    }
    header @static_files {
        Cache-Control "public, immutable, max-age=31536000"
    }
}
